#!/bin/sh /etc/rc.common

USE_PROCD=1
START=99
STOP=10

start_service() {
	local enabled config_file

	config_load nezha-agent
	config_get_bool enabled main enabled 0
	[ "$enabled" -eq 1 ] || return 0

	config_get config_file main config_file /etc/nezha-agent/config.yml

	[ -x /usr/bin/nezha-agent ] || {
		logger -t nezha-agent "Executable not found: /usr/bin/nezha-agent"
		return 1
	}

	/usr/libexec/nezha-agent-manager sync-config || return 1

	procd_open_instance
	procd_set_param command /usr/bin/nezha-agent -c "$config_file"
	procd_set_param respawn 3600 5 5
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_set_param limits nofile="65535 65535"
	procd_close_instance
}

reload_service() {
	stop
	start
}

service_triggers() {
	procd_add_reload_trigger nezha-agent
}
