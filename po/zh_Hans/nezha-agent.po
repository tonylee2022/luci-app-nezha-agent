msgid "Nezha Agent"
msgstr "哪吒监控 Agent"

msgid "Settings"
msgstr "设置"

msgid "Configure and manage the Nezha monitoring agent."
msgstr "配置并管理哪吒监控 Agent。"

msgid "Agent Settings"
msgstr "Agent 设置"

msgid "Enable"
msgstr "启用"

msgid "V1 installation command"
msgstr "V1 安装命令"

msgid "Paste the Linux installation command generated by the Nezha V1 dashboard. The command is parsed locally and is not saved."
msgstr "粘贴哪吒 V1 面板生成的 Linux 安装命令。命令仅在本地解析，不会保存。"

msgid "Import installation command"
msgstr "导入安装命令"

msgid "Parse and fill"
msgstr "解析并填充"

msgid "Unable to parse the installation command. Ensure it contains valid NZ_SERVER and NZ_CLIENT_SECRET values."
msgstr "无法解析安装命令，请确认命令包含有效的 NZ_SERVER 和 NZ_CLIENT_SECRET。"

msgid "Installation command parsed. Review the values, then save and apply the configuration."
msgstr "安装命令解析成功，请核对参数后保存并应用配置。"

msgid "Configuration file"
msgstr "配置文件"

msgid "Dashboard server"
msgstr "面板服务器"

msgid "Server address in host:port format."
msgstr "服务器地址，格式为 主机:端口。"

msgid "Client secret"
msgstr "客户端密钥"

msgid "Agent UUID"
msgstr "Agent UUID"

msgid "Leave empty to generate a new UUID when the configuration is applied."
msgstr "留空将在应用配置时生成新的 UUID。"

msgid "UUID must not contain whitespace or control characters."
msgstr "UUID 不能包含空白或控制字符。"

msgid "Enable TLS"
msgstr "启用 TLS"

msgid "Skip TLS verification"
msgstr "跳过 TLS 证书验证"

msgid "Disable agent auto-update"
msgstr "禁用 Agent 自动更新"

msgid "Disable forced updates"
msgstr "禁用强制更新"

msgid "Disable remote command execution"
msgstr "禁用远程命令执行"

msgid "Disable NAT traversal"
msgstr "禁用内网穿透"

msgid "Disable network query tasks"
msgstr "禁用网络探测任务"

msgid "Report interval"
msgstr "上报间隔"

msgid "Status reporting interval in seconds, from 1 to 4."
msgstr "状态上报间隔，单位为秒，范围为 1 到 4。"

msgid "Custom IP APIs"
msgstr "自定义 IP 查询 API"

msgid "Add the API domains to the direct-connect rules of OpenClash, PassWall, or other proxy software to obtain the real public IP address."
msgstr "请将 API 域名加入 OpenClash、PassWall 或其他代理软件的直连规则，以获取真实公网 IP。"

msgid "Service status"
msgstr "服务状态"

msgid "Collecting data..."
msgstr "正在获取数据..."

msgid "Running"
msgstr "运行中"

msgid "Not running"
msgstr "未运行"
